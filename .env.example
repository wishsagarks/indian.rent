# SUPABASE CONFIGURATION
# Get these from your Supabase Dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-supabase-url.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# SUPABASE SERVICE ROLE KEY (for backend imports/cron jobs)
# Get from Supabase Dashboard -> Settings -> API -> Service Role secret (NOT the anon key)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# CRON SECRET (for scheduled import authorization)
# Generate: openssl rand -base64 32
CRON_SECRET=your_cron_secret_here

# MAP CONFIGURATION
# Choose between 'mapbox' or 'google'
NEXT_PUBLIC_MAP_PROVIDER=google

# MAPBOX CONFIGURATION (Public token for client-side usage)
# Get this from your Mapbox Account -> Tokens
# IMPORTANT: This is a public token, OK to be in NEXT_PUBLIC
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=pk.your_mapbox_token_here

# GOOGLE MAPS CONFIGURATION
# ⚠️  CLIENT-SIDE ONLY (Public token)
# Get this from your Google Cloud Console -> APIs & Services -> Credentials
# IMPORTANT: This is restricted to browser origins, client-side use ONLY
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=AIzaSyYour_public_key_here

# GOOGLE MAPS SERVER-SIDE API KEY (Private, IP-restricted) — CRITICAL SECURITY FIX
# ⚠️  CRITICAL: This must be a DIFFERENT key from NEXT_PUBLIC_GOOGLE_MAPS_API_KEY
# Setup instructions:
#   1. Go to Google Cloud Console -> APIs & Services -> Credentials
#   2. Create a NEW API key (not restricting by origin, but by IP)
#   3. In the "Restrict keys" section, select "IP addresses"
#   4. Add your production server's IP address (e.g., 203.0.113.45)
#   5. Copy the full key and paste here
# This key is ONLY used for server-side reverse geocoding in reverseGeocode()
GOOGLE_MAPS_API_KEY_SERVER=your_server_only_key_here

# UPSTASH REDIS CONFIGURATION (Rate Limiting Only)
# Get these from your Upstash Console -> Redis -> Your Database
# Set REDIS_ENABLED=false to disable Redis entirely (app still works without it)
REDIS_ENABLED=true
UPSTASH_REDIS_REST_URL=https://your-upstash-url.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_redis_token_here

# SITE CONFIGURATION
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# DRIVER.JS CONFIGURATION
# Set to 'true' to enable guided tours (onboarding)
NEXT_PUBLIC_DRIVER_JS_ENABLED=true
