# SUPABASE CONFIGURATION
# Get these from your Supabase Dashboard -> Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# MAP CONFIGURATION
# Choose between 'mapbox' or 'google'
NEXT_PUBLIC_MAP_PROVIDER=google

# MAPBOX CONFIGURATION
# Get this from your Mapbox Account -> Tokens
NEXT_PUBLIC_MAPBOX_ACCESS_TOKEN=your-mapbox-access-token-here

# GOOGLE MAPS CONFIGURATION
# Get this from your Google Cloud Console -> APIs & Services -> Credentials
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-google-maps-api-key-here

# UPSTASH REDIS CONFIGURATION (Rate Limiting Only)
# Get these from your Upstash Console -> Redis -> Your Database
# Set REDIS_ENABLED=false to disable Redis entirely (app still works without it)
REDIS_ENABLED=true
UPSTASH_REDIS_REST_URL=https://your-database-id.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-rest-token-here

# SITE CONFIGURATION
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# DRIVER.JS CONFIGURATION
# Set to 'true' to enable guided tours (onboarding)
NEXT_PUBLIC_DRIVER_JS_ENABLED=true
