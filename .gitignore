# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# Ignore markdown files except project documentation
*.md
!README.md
!WIKI.md
!ARCHITECTURE.md
!CONTRIBUTING.md
!GETTING_STARTED.md
!DOCS_INDEX.md
!LICENSE

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env.local*
.env.production*
.bolt
# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
CLAUDE.md
GEMINI.md
.venv
graphify-out/
conversations-resume.txt
.claude/
.gemini/
.env

# Data source references (local only, not committed)
src/app/api/cron/
src/utils/data-sources/
src/app/actions/*-import*.ts
*import-config*
*data-source*
*.scrape*
